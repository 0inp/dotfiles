{
  "$schema": "https://opencode.ai/schemas/pi-agent-config",
  "version": "1.0",
  "model": {
    "name": "mistral-large-latest",
    "temperature": 0.2,
    "max_tokens": 4096,
    "top_p": 0.95
  },
  "tools": {
    "enabled": [
      "read",
      "bash",
      "edit",
      "write",
      "grep",
      "glob",
      "webfetch",
      "task",
      "skill",
      "question"
    ],
    "excluded": []
  },
  "guardrails": {
    "read_before_edit": true,
    "grep_before_assume": true,
    "ask_before_act": true,
    "verify_after_change": true,
    "cite_sources": true,
    "irreversible_actions": {
      "require_confirmation": true,
      "auto_clarity": true
    }
  },
  "mcp": {
    "router": {
      "priority": [
        "read",
        "grep",
        "glob",
        "bash",
        "webfetch",
        "task",
        "edit",
        "write",
        "skill"
      ],
      "rate_limits": {
        "skill": 2,
        "task": 3
      }
    },
    "user_confirmation": {
      "required_for": [
        "edit",
        "write",
        "skill"
      ]
    }
  },
  "skills": {
    "always_active": [
      "caveman"
    ],
    "load_on_demand": [
      "grill-with-docs",
      "diagnose",
      "tdd",
      "improve-codebase-architecture"
    ]
  },
  "verification": {
    "commands": {
      "lint": "echo 'No lint command configured for this project'",
      "test": "echo 'No test command configured for this project'"
    },
    "user_confirmation": {
      "major_changes": true
    }
  },
  "extensions": {}
}